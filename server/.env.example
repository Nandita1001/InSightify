PORT=4000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/insightify

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=7d

CORS_ORIGIN=http://localhost:5173

# Groq (optional). Without it, /api/llm/* returns 503 and client falls back to local templates.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.1

# RAG retrieval. "memory" works out of the box. "atlas" requires creating a
# vector search index on the documentchunks collection (see README).
RETRIEVAL_BACKEND=memory
ATLAS_VECTOR_INDEX=vector_index
