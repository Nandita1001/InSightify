PORT=4000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/insightify

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_TTL=7d

CORS_ORIGIN=http://localhost:5173

# Groq (optional). Without it, /api/llm/* returns 503 and client falls back to local templates.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.1
